#include <iostream>
using namespace std;

class Complex {
public:
    int real, imag;

    // constructor
    Complex(int r=0, int i=0){
        real = r;
        imag = i;
    }

    // overload +
    Complex operator+(Complex c){
        return Complex(real + c.real, imag + c.imag);
    }

    // overload -
    Complex operator-(Complex c){
        return Complex(real - c.real, imag - c.imag);
    }

    void show(){
        cout << real << " + " << imag << "i" << endl;
    }
};

int main() {
    Complex c1(4,5);
    Complex c2(2,3);

    Complex sum = c1 + c2;
    Complex diff = c1 - c2;

    cout << "Addition: ";
    sum.show();

    cout << "Subtraction: ";
    diff.show();
}